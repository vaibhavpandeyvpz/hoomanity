{
  "name": "hoomanity",
  "version": "0.3.2",
  "description": "Interactive CLI for multi-agent setups. Run `hoomanity` to pick an agent; `hoomanity configure` for create/edit, skills, MCP, and settings.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaibhavpandeyvpz/hoomanity.git"
  },
  "bugs": {
    "url": "https://github.com/vaibhavpandeyvpz/hoomanity/issues"
  },
  "homepage": "https://github.com/vaibhavpandeyvpz/hoomanity#readme",
  "type": "module",
  "bin": {
    "hoomanity": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cli",
    "ai",
    "agents",
    "openai",
    "mcp",
    "ink",
    "react",
    "ollama",
    "bedrock",
    "anthropic"
  ],
  "scripts": {
    "build": "rimraf dist && tsc && node scripts/copy-prompts.mjs",
    "dev": "tsx src/cli.tsx",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.85",
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/openai": "^3.0.49",
    "@one710/recollect": "^1.7.0",
    "@openai/agents": "^0.8.2",
    "@openai/agents-extensions": "^0.8.2",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.15.0",
    "ai": "^6.0.145",
    "ai-sdk-ollama": "^3.8.2",
    "chokidar": "^5.0.0",
    "cli-spinners": "^3.4.0",
    "front-matter": "^4.0.2",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "slugify": "^1.6.9",
    "whatsapp-web.js": "^1.34.6",
    "winston": "^3.19.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/node": "^22.19.3",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.7",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
